{
    "version": 2,
    "buildCommand": "npm run build && npx prisma migrate deploy",
    "installCommand": "npm install",
    "outputDirectory": "build",
    "builds": [
      {
        "src": "src/server.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "src/server.js"
      }
    ]
  }
  
  